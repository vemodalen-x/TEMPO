{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.local/schemas/task.schema.json",
  "title": "TEMPO Governed Task",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "lane", "scope_in", "scope_out", "hypothesis_refs", "charter_ref", "opportunity_ref"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^T-[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "title": {"type": "string", "minLength": 1, "maxLength": 500},
    "state": {"type": "string", "enum": ["proposed", "active", "completed", "blocked", "cancelled"]},
    "risk": {"type": "string", "pattern": "^R[0-4]$"},
    "demo_tier": {"type": "string", "pattern": "^D[0-3]$"},
    "owner": {"type": "string", "pattern": "^(?:human|agent|kernel|verifier|platform):[A-Za-z0-9][A-Za-z0-9._@+:/-]{1,127}$"},
    "lane": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$"},
    "scope_in": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/pathGlob"}},
    "scope_out": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 500}},
    "hypothesis_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/stableRef"}},
    "charter_ref": {"$ref": "#/$defs/stableRef"},
    "opportunity_ref": {"$ref": "#/$defs/stableRef"},
    "budget": {"$ref": "#/$defs/money"},
    "deadline": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "stableRef": {"type": "string", "pattern": "^[A-Z][A-Z0-9]{0,7}-[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "pathGlob": {"type": "string", "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\u0000]+$", "maxLength": 500},
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency"],
      "properties": {
        "amount": {"type": "number", "minimum": 0},
        "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}
      }
    }
  }
}
